# Secrets for Papermark deployment. All fetched from 1Password.
# Vault: Papermark

# Database
DB_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/Database Credentials" DB_USERNAME DB_PASSWORD POSTGRES_DB)
DB_USERNAME=$(kamal secrets extract DB_USERNAME ${DB_SECRETS})
DB_PASSWORD=$(kamal secrets extract DB_PASSWORD ${DB_SECRETS})
POSTGRES_USER=$DB_USERNAME
POSTGRES_DB=$(kamal secrets extract POSTGRES_DB ${DB_SECRETS})
POSTGRES_PASSWORD=$DB_PASSWORD
POSTGRES_PRISMA_URL="postgresql://${DB_USERNAME}:${DB_PASSWORD}@papermark-db:5432/${POSTGRES_DB}"
POSTGRES_PRISMA_URL_NON_POOLING=$POSTGRES_PRISMA_URL

# Auth (NextAuth + Google OAuth)
AUTH_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/Auth Credentials" NEXTAUTH_SECRET GOOGLE_CLIENT_ID GOOGLE_CLIENT_SECRET)
NEXTAUTH_SECRET=$(kamal secrets extract NEXTAUTH_SECRET ${AUTH_SECRETS})
GOOGLE_CLIENT_ID=$(kamal secrets extract GOOGLE_CLIENT_ID ${AUTH_SECRETS})
GOOGLE_CLIENT_SECRET=$(kamal secrets extract GOOGLE_CLIENT_SECRET ${AUTH_SECRETS})

# SMTP (replaces Resend)
SMTP_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/SMTP Credentials" SMTP_SERVER SMTP_PORT SMTP_USERNAME SMTP_PASSWORD MAILER_FROM)
SMTP_HOST=$(kamal secrets extract SMTP_SERVER ${SMTP_SECRETS})
SMTP_PORT=$(kamal secrets extract SMTP_PORT ${SMTP_SECRETS})
SMTP_USER=$(kamal secrets extract SMTP_USERNAME ${SMTP_SECRETS})
SMTP_PASSWORD=$(kamal secrets extract SMTP_PASSWORD ${SMTP_SECRETS})
SMTP_FROM_ADDRESS=$(kamal secrets extract MAILER_FROM ${SMTP_SECRETS})

# Redis SRH (self-hosted Redis with Upstash-compatible REST API)
REDIS_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/Redis SRH" SRH_TOKEN SRH_LOCKER_TOKEN)
SRH_TOKEN=$(kamal secrets extract SRH_TOKEN ${REDIS_SECRETS})
SRH_LOCKER_TOKEN=$(kamal secrets extract SRH_LOCKER_TOKEN ${REDIS_SECRETS})
UPSTASH_REDIS_REST_URL="http://papermark-srh:8079"
UPSTASH_REDIS_REST_TOKEN=$SRH_TOKEN
UPSTASH_REDIS_REST_LOCKER_URL="http://papermark-srh-locker:8079"
UPSTASH_REDIS_REST_LOCKER_TOKEN=$SRH_LOCKER_TOKEN

# Tinybird (analytics)
TINYBIRD_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/Tinybird" credential url)
TINYBIRD_TOKEN=$(kamal secrets extract credential ${TINYBIRD_SECRETS})
TINYBIRD_BASE_URL=$(kamal secrets extract url ${TINYBIRD_SECRETS})

# Trigger.dev (background jobs — critical for doc conversion, downloads, video)
TRIGGER_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/Trigger.dev" SECRET_KEY)
TRIGGER_SECRET_KEY=$(kamal secrets extract SECRET_KEY ${TRIGGER_SECRETS})

# AWS S3 (file storage)
S3_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/AWS S3" ACCESS_KEY_ID SECRET_ACCESS_KEY BUCKET_NAME REGION DISTRIBUTION_HOST)
NEXT_PRIVATE_UPLOAD_ACCESS_KEY_ID=$(kamal secrets extract ACCESS_KEY_ID ${S3_SECRETS})
NEXT_PRIVATE_UPLOAD_SECRET_ACCESS_KEY=$(kamal secrets extract SECRET_ACCESS_KEY ${S3_SECRETS})
NEXT_PRIVATE_UPLOAD_BUCKET=$(kamal secrets extract BUCKET_NAME ${S3_SECRETS})
NEXT_PRIVATE_UPLOAD_REGION=$(kamal secrets extract REGION ${S3_SECRETS})
NEXT_PRIVATE_UPLOAD_DISTRIBUTION_HOST=$(kamal secrets extract DISTRIBUTION_HOST ${S3_SECRETS})

# App secrets
APP_SECRETS=$(kamal secrets fetch --adapter 1password --account my.1password.com --from "Papermark/App Secrets" DOCUMENT_PASSWORD_KEY VERIFICATION_SECRET INTERNAL_API_KEY)
NEXT_PRIVATE_DOCUMENT_PASSWORD_KEY=$(kamal secrets extract DOCUMENT_PASSWORD_KEY ${APP_SECRETS})
NEXT_PRIVATE_VERIFICATION_SECRET=$(kamal secrets extract VERIFICATION_SECRET ${APP_SECRETS})
INTERNAL_API_KEY=$(kamal secrets extract INTERNAL_API_KEY ${APP_SECRETS})
